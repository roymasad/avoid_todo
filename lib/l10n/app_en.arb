  "onboardingWelcomeTitle": "Stop the Habits Holding You Back",
  "@onboardingWelcomeTitle": { "description": "Onboarding slide 1 title." },
  "onboardingWelcomeDesc": "Most apps track what to DO. Avoid tracks what to STOP — the habits, urges, and patterns getting in your way. Add what you want to quit, log when you slip, and build streaks that matter.",
  "@onboardingWelcomeDesc": { "description": "Onboarding slide 1 description." },
  "onboardingTagsTitle": "Organize with Tags",
  "@onboardingTagsTitle": { "description": "Onboarding slide 2 title." },
  "onboardingTagsDesc": "Group habits by area of life — Health, Work, Social. See at a glance which part of your life needs the most attention right now.",
  "@onboardingTagsDesc": { "description": "Onboarding slide 2 description." },
  "onboardingMoneyTitle": "Every Slip Has a Cost",
  "@onboardingMoneyTitle": { "description": "Onboarding slide 3 title." },
  "onboardingMoneyDesc": "Set an estimated cost per slip (e.g. a cigarette pack, a takeout meal). Avoid multiplies it by your streak to show you the real money you've saved.",
  "@onboardingMoneyDesc": { "description": "Onboarding slide 3 description." },
  "onboardingRelapseTitle": "Slipped? That's OK — Log It",
  "@onboardingRelapseTitle": { "description": "Onboarding slide 4 title." },
  "onboardingRelapseDesc": "Tap Slip to record what triggered you. Over time, Avoid spots your patterns so you can get ahead of them. No judgment, just awareness.",
  "@onboardingRelapseDesc": { "description": "Onboarding slide 4 description." },
  "onboardingBadgesTitle": "Earn Rewards Along the Way",
  "@onboardingBadgesTitle": { "description": "Onboarding slide 5 title." },
  "onboardingBadgesDesc": "Unlock badges for streaks and savings milestones. Complete goals, earn XP, and level up through 50 tiers as your habits get stronger.",
  "@onboardingBadgesDesc": { "description": "Onboarding slide 5 description." },
