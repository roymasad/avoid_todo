  "helpWhatIsAvoidTitle": "What is Avoid?",
  "@helpWhatIsAvoidTitle": {
    "description": "Help screen intro section title."
  },
  "helpWhatIsAvoidDesc": "Avoid helps you break bad habits by tracking what you want to STOP doing. Add a habit, log when you slip, and note what triggered you. Over time you'll spot your patterns, build long streaks, and see the real impact — in money, mood, or time — of staying clean.",
  "@helpWhatIsAvoidDesc": {
    "description": "Help screen intro section description."
  },
  "faq1Question": "How do I add something to avoid?",
  "@faq1Question": {
    "description": "FAQ 1 question."
  },
  "faq1Answer": "Tap the + button at the bottom right. You can add a recurring habit (like smoking or junk food), a one-time event (like skipping a party), a person to avoid, or even a location. Set an optional cost and reminder to keep yourself accountable.",
  "@faq1Answer": {
    "description": "FAQ 1 answer."
  },
  "faq2Question": "What is a slip and how do I log one?",
  "@faq2Question": {
    "description": "FAQ 2 question."
  },
  "faq2Answer": "A slip (relapse) is when you give in to something you're trying to avoid. Tap the red Slip button on any habit card. You can add a quick note about what triggered you — this builds your trigger history and helps you spot patterns over time.",
  "@faq2Answer": {
    "description": "FAQ 2 answer."
  },
  "faq3Question": "How are streaks calculated?",
  "@faq3Question": {
    "description": "FAQ 3 question."
  },
  "faq3Answer": "Your streak counts the days since your last slip. For recurring habits it resets each time you slip. For one-time events it tracks until you archive the item.",
  "@faq3Answer": {
    "description": "FAQ 3 answer."
  },
  "faq4Question": "How does money (or time/mood) tracking work?",
  "@faq4Question": {
    "description": "FAQ 4 question."
  },
  "faq4Answer": "When adding a habit, set an estimated cost per slip — in money, hours, or mood points. Avoid multiplies this by your streak duration to show the total you've saved by staying clean.",
  "@faq4Answer": {
    "description": "FAQ 4 answer."
  },
  "faq5Question": "What are goals and how do I use them?",
  "@faq5Question": {
    "description": "FAQ 5 question."
  },
  "faq5Answer": "Goals give you a specific target, like reaching a 7-day streak on your hardest habit. Everyone gets an auto-generated goal based on their most-relapsed habit. Plus users can also create custom goals and track savings targets.",
  "@faq5Answer": {
    "description": "FAQ 5 answer."
  },
  "faq6Question": "How does XP and leveling work?",
  "@faq6Question": {
    "description": "FAQ 6 question."
  },
  "faq6Answer": "You earn XP by avoiding slips, completing goals, and doing the daily commitment. There are 100 levels with titles — free users progress to level 20, Plus unlocks all 100.",
  "@faq6Answer": {
    "description": "FAQ 6 answer."
  },
  "faq7Question": "What is the Daily Commitment? (Plus)",
  "@faq7Question": {
    "description": "FAQ 7 question."
  },
  "faq7Answer": "Plus users see a morning screen once per day to commit to their active habits. Each commitment earns +20 XP and builds a daily ritual around your goals.",
  "@faq7Answer": {
    "description": "FAQ 7 answer."
  },
  "faq8Question": "Can I track people or locations to avoid?",
  "@faq8Question": {
    "description": "FAQ 8 question."
  },
  "faq8Answer": "Yes! When adding a habit choose 'Person' to link it to a contact from your phonebook, or 'Location' to pin a spot on the map. Great for avoiding difficult people or triggering environments.",
  "@faq8Answer": {
    "description": "FAQ 8 answer."
  },
  "faq9Question": "What does Avoid Plus include?",
  "@faq9Question": {
    "description": "FAQ 9 question."
  },
  "faq9Answer": "Plus is a one-time purchase that unlocks: unlimited habits, full stats history & heatmap, relapse pattern analysis, custom goals, daily commitment (+XP), smart pattern-aware notifications, home screen widget, cloud backup, and data export.",
  "@faq9Answer": {
    "description": "FAQ 9 answer."
  },
  "faq10Question": "Is my data stored in the cloud?",
  "@faq10Question": {
    "description": "FAQ 10 question."
  },
  "faq10Answer": "No. Avoid does not process, collect, or store your habit data on our own servers. Your data stays on your device. If you enable cloud backup, it is saved to your own iCloud or Google Drive account, not to Avoid's cloud.",
  "@faq10Answer": {
    "description": "FAQ 10 answer."
  },
