<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="14dp">

    <!-- "AVOIDING X HABITS" — top-left, updated dynamically -->
    <TextView
        android:id="@+id/widget_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:text="AVOIDING 3 HABITS"
        android:textColor="#88FFFFFF"
        android:textSize="9sp"
        android:letterSpacing="0.15"
        android:textAllCaps="true" />

    <!-- Open-app icon — top-right tap zone -->
    <TextView
        android:id="@+id/widget_open_app"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:text="↗"
        android:textColor="#55FFFFFF"
        android:textSize="14sp"
        android:padding="2dp" />

    <!-- Centre content: habit name + streak pill + label -->
    <LinearLayout
        android:id="@+id/widget_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/widget_habit_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your top habit"
            android:textColor="#EEFFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="8dp" />

        <!-- Frosted streak pill -->
        <LinearLayout
            android:id="@+id/widget_streak_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/widget_streak_badge"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/widget_streak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="21 days"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/widget_streak_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥 streak‑free"
            android:textColor="#99FFFFFF"
            android:textSize="10sp"
            android:layout_marginTop="5dp" />

    </LinearLayout>

</RelativeLayout>
